# Erlaubter Browser-Origin (die URL, unter der die App laeuft). Genau setzen (kein "*").
# Fuer Weg A UND Weg B noetig.
ALLOW_ORIGIN=https://lernapp-mauve.vercel.app

# Nur fuer Weg B (docker-compose.caddy.yml): Domain, die per DNS auf diesen VPS zeigt.
# Caddy holt dafuer automatisch ein TLS-Zertifikat. Bei Weg A (hinter Traefik/nginx)
# ignoriert und kann leer bleiben.
DOMAIN=backup.deine-domain.de
